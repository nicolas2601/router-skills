{
  "name": "router-skills",
  "version": "0.4.0",
  "description": "Force Claude Code & opencode to evaluate and use Agent Skills on every turn — cross-platform provisioner",
  "type": "module",
  "bin": {
    "router-skills": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "install:all": "bun run src/index.ts --yes",
    "dry": "bun run src/index.ts --dry-run",
    "test": "bun test src/",
    "build": "bun run build:linux && bun run build:win && bun run build:mac",
    "build:linux": "bun build --compile --target=bun-linux-x64 --outfile dist/router-skills src/index.ts",
    "build:win": "bun build --compile --target=bun-windows-x64 --outfile dist/router-skills.exe src/index.ts",
    "build:mac": "bun build --compile --target=bun-darwin-arm64 --outfile dist/router-skills-macos src/index.ts",
    "typecheck": "tsc --noEmit",
    "validate": "bun run scripts/validate-pack.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
